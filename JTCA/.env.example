# ============================================================
# JTCA Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-3.5-flash

# App Settings
APP_NAME=JTCA - Jabil TradeAI Compliance Assistant
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Confidence Threshold for Auto-Approval
CONFIDENCE_THRESHOLD=90

# Database Path (default: data/jtca.db)
DB_PATH=data/jtca.db

# ChromaDB Storage Path
CHROMA_PATH=data/chroma_store

# ── MongoDB (raw crawl storage) ──────────────────────────────
# Docker: mongodb://jtca_user:jtca_pass@localhost:27017/
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/
MONGO_URI=mongodb://jtca_user:jtca_pass@localhost:27017/
MONGO_DB_NAME=jtca_raw

# ── PostgreSQL (structured data) ─────────────────────────────
# Docker: postgresql://jtca_user:jtca_pass@localhost:5432/jtca
# Cloud:  postgresql://<user>:<pass>@<host>:5432/<dbname>
POSTGRES_URI=postgresql://jtca_user:jtca_pass@localhost:5432/jtca
